<?xml version="1.0" encoding="UTF-8" ?>
<UserControl
    x:Class="Lan.Shapes.DialogGeometry.Dialog.DxfImportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:Lan.Shapes.DialogGeometry.Dialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="400"
    Height="250"
    d:Background="White"
    d:DataContext="{d:DesignInstance local:DxfImportDialogViewModel}"
    d:DesignHeight="250"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <hc:ThemeResources />
                <hc:Theme />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <StackPanel Margin="0,10,0,10">
        <TextBlock
            FontSize="16"
            FontWeight="Bold"
            Margin="5"
            Text="DXF Import" />

        <DockPanel Margin="5">
            <Button
                DockPanel.Dock="Right"
                Margin="5,0,0,0"
                Width="80"
                Command="{Binding BrowseCommand}"
                Content="Browse..." />
            <hc:TextBox
                hc:InfoElement.ShowClearButton="True"
                hc:InfoElement.Title="File Path"
                hc:InfoElement.TitlePlacement="Left"
                hc:InfoElement.TitleWidth="80"
                FontSize="14"
                Text="{Binding FilePath}" />
        </DockPanel>

        <hc:TextBox
            Margin="5"
            hc:InfoElement.HorizontalAlignment="Right"
            hc:InfoElement.ShowClearButton="True"
            hc:InfoElement.Title="Pixel/MM"
            hc:InfoElement.TitlePlacement="Left"
            hc:InfoElement.TitleWidth="80"
            FontSize="16"
            Text="{Binding PixelToMmFactor}">
            <hc:TextBox.InputBindings>
                <KeyBinding Key="Enter" Command="{Binding CloseCommand}" />
            </hc:TextBox.InputBindings>
        </hc:TextBox>

        <StackPanel
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="90"
                Height="35"
                Margin="5"
                Command="{Binding OkCommand}"
                Content="OK"
                FontSize="16">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource ButtonPrimary}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FilePath}" Value="">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FilePath}" Value="{x:Null}">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button
                Width="90"
                Height="35"
                Margin="5"
                Command="{Binding CancelCommand}"
                Content="Cancel"
                FontSize="16"
                Style="{StaticResource ButtonWarning}" />
        </StackPanel>
    </StackPanel>
</UserControl>
